# 本地开发环境变量说明
# 推荐做法：先在 Vercel 中创建项目并接入所需服务，再执行 `vercel env pull .env.local`
# 这样可以一次性把大部分值同步到本地。

# AUTH_SECRET
# 含义：NextAuth/Auth.js 用来签名和校验会话、JWT、Cookie 的密钥。
# 用途：登录鉴权、游客会话、受保护路由访问都依赖它。
# 是否必须：是。本地运行建议始终配置。
# 获取方式：本机直接生成即可，不需要去平台申请。
# 生成示例：`openssl rand -base64 32`
# 备用生成器：https://generate-secret.vercel.app/32
AUTH_SECRET=****

# AI_GATEWAY_API_KEY
# 含义：Vercel AI Gateway 的 API Key。
# 用途：本地或非 Vercel 环境访问 AI Gateway 时鉴权使用。
# 是否必须：如果你继续使用当前项目默认的 AI Gateway 接入方式，则是必须。
# 获取方式：在 Vercel 控制台打开 AI Gateway，创建一个 API Key 后填入这里。
# 文档：https://vercel.com/ai-gateway
AI_GATEWAY_API_KEY=****

# ANTHROPIC_API_KEY
# 含义：Claude 提供方的鉴权凭证。
# 用途：当你选择 Claude 模型时使用；原有 AI Gateway 模型保持不变。
# 是否必须：不是。只有你要用 Claude 直连时才需要填写。
# 获取方式：
# 1) 如果直连 Anthropic，填 Anthropic Console 里创建的 API Key。
# 2) 如果走 qnaigc 这类 Anthropic 兼容网关，填该平台提供的 Bearer Token。
# 3) 如果走 OpenAI 兼容代理（如 newapi.dzkjm.cn），填该平台提供的 API Key。
# Anthropic 控制台：https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=****

# ANTHROPIC_BASE_URL
# 含义：Claude / AI 模型的自定义代理地址。
# 用途：给 AI SDK 指定自定义网关地址。
# 是否必须：仅在你不直连 Anthropic、而是走兼容网关时需要。
# 获取方式：由对应平台文档提供。
# qnaigc 示例（Anthropic 协议）：https://api.qnaigc.com
# OpenAI 兼容代理示例：https://newapi.dzkjm.cn
ANTHROPIC_BASE_URL=

# BLOB_READ_WRITE_TOKEN
# 含义：Vercel Blob 的读写令牌。
# 用途：文件上传接口会用它把图片等文件存到 Blob 存储。
# 是否必须：如果你要使用上传附件/图片相关功能，则需要；只想先跑基础聊天，可后补。
# 获取方式：在 Vercel 控制台为项目接入 Blob 存储后，复制生成的读写 Token。
# 文档：https://vercel.com/docs/vercel-blob
BLOB_READ_WRITE_TOKEN=****

# POSTGRES_URL
# 含义：Postgres 数据库连接串。
# 用途：用户、聊天记录、消息、文档等数据都会持久化到这里；Drizzle 迁移也依赖它。
# 是否必须：基本必需。没有它，迁移会跳过，应用的数据功能也无法正常工作。
# 获取方式：在 Vercel Postgres、Neon 或其他 Postgres 服务中创建数据库后，复制连接 URL。
# 文档：https://vercel.com/docs/postgres
POSTGRES_URL=****

# REDIS_URL
# 含义：Redis 连接地址。
# 用途：用于限流，以及聊天流式响应的可恢复能力。
# 是否必须：本地通常不是硬性必需；不配置时相关能力会降级，但基础功能一般仍可运行。
# 获取方式：在 Vercel KV、Upstash Redis 或其他 Redis 服务中创建实例后复制连接 URL。
# 文档：https://vercel.com/docs/redis
REDIS_URL=****
